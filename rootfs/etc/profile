export PATH=/bin:/sbin:/usr/bin:/usr/sbin
export PS1='\[\e[32m\]sdul\[\e[0m\]:\[\e[34m\]\w\[\e[0m\]# '
alias ll='ls -la'
alias ..='cd ..'

# Show command list on login
sdulhelp() {
    echo ""
    echo "  SDUL Command Reference"
    echo "  ======================"
    echo ""
    echo "  FILE MANAGEMENT"
    echo "  ls                   - list files in current directory"
    echo "  ls -la               - list all files with permissions and sizes"
    echo "  ls -lh               - list files with human readable sizes"
    echo "  cd <dir>             - change to a directory"
    echo "  cd ..                - go up one directory"
    echo "  cd /                 - go to root directory"
    echo "  cd ~                 - go to home directory"
    echo "  pwd                  - print the current directory path"
    echo "  mkdir <dir>          - create a new directory"
    echo "  mkdir -p <a/b/c>     - create nested directories"
    echo "  rmdir <dir>          - remove an empty directory"
    echo "  rm <file>            - delete a file"
    echo "  rm -rf <dir>         - delete a directory and everything in it"
    echo "  cp <src> <dst>       - copy a file"
    echo "  cp -r <src> <dst>    - copy a directory recursively"
    echo "  mv <src> <dst>       - move or rename a file or directory"
    echo "  touch <file>         - create an empty file or update timestamp"
    echo "  cat <file>           - print the contents of a file"
    echo "  more <file>          - page through a file one screen at a time"
    echo "  head <file>          - show the first 10 lines of a file"
    echo "  head -n 20 <file>    - show the first 20 lines of a file"
    echo "  tail <file>          - show the last 10 lines of a file"
    echo "  tail -f <file>       - follow a file as it grows in real time"
    echo "  wc <file>            - count lines, words, and characters"
    echo "  wc -l <file>         - count only lines"
    echo "  find <dir> -name x   - search for a file by name"
    echo "  find . -type f       - find all files in current directory"
    echo "  chmod 755 <file>     - set file permissions to rwxr-xr-x"
    echo "  chmod +x <file>      - make a file executable"
    echo "  chown user <file>    - change the owner of a file"
    echo "  ln -s <src> <dst>    - create a symbolic link"
    echo "  stat <file>          - show detailed file info"
    echo "  file <file>          - detect the type of a file"
    echo ""
    echo "  TEXT PROCESSING"
    echo "  grep <pattern> <f>   - search for a pattern in a file"
    echo "  grep -r <pat> <dir>  - search recursively in a directory"
    echo "  grep -i <pat> <f>    - case insensitive search"
    echo "  grep -n <pat> <f>    - show line numbers with matches"
    echo "  sed 's/a/b/' <file>  - replace first 'a' with 'b' per line"
    echo "  sed 's/a/b/g' <file> - replace all 'a' with 'b'"
    echo "  awk '{print \$1}' <f> - print first column of each line"
    echo "  sort <file>          - sort lines alphabetically"
    echo "  sort -n <file>       - sort lines numerically"
    echo "  sort -r <file>       - sort lines in reverse"
    echo "  uniq <file>          - remove consecutive duplicate lines"
    echo "  cut -d: -f1 <file>   - cut first field using : as delimiter"
    echo "  tr 'a-z' 'A-Z'       - translate lowercase to uppercase"
    echo "  echo <text>          - print text to the screen"
    echo "  echo \$VAR            - print value of a variable"
    echo "  printf               - formatted text output"
    echo ""
    echo "  EDITOR"
    echo "  edit <file>          - edit a file line by line"
    echo "    i                  - enter insert mode"
    echo "    Esc                - exit insert mode"
    echo "    :w                 - save file"
    echo "    :q                 - quit"
    echo "    :wq                - save and quit"
    echo "    :q!                - quit without saving"
    echo "    dd                 - delete current line"
    echo "    yy                 - copy current line"
    echo "    p                  - paste"
    echo ""
    echo "  PROCESSES"
    echo "  ps                   - list your running processes"
    echo "  ps aux               - list all running processes"
    echo "  top                  - live interactive process monitor"
    echo "  kill <pid>           - send TERM signal to a process"
    echo "  kill -9 <pid>        - force kill a process immediately"
    echo "  killall <name>       - kill all processes with that name"
    echo "  sleep <seconds>      - pause for N seconds"
    echo "  time <command>       - measure how long a command takes"
    echo "  nohup <command>      - run command that survives logout"
    echo "  nice -n 10 <cmd>     - run command with lower priority"
    echo "  bg                   - resume a stopped job in background"
    echo "  fg                   - bring background job to foreground"
    echo "  jobs                 - list background jobs"
    echo ""
    echo "  DISK AND MEMORY"
    echo "  free                 - show total, used, and free memory"
    echo "  free -h              - show memory in human readable format"
    echo "  df                   - show disk space on all filesystems"
    echo "  df -h                - show disk space human readable"
    echo "  du <dir>             - show disk usage of a directory"
    echo "  du -sh <dir>         - show total size of a directory"
    echo "  mount                - list all mounted filesystems"
    echo "  mount <dev> <dir>    - mount a device to a directory"
    echo "  umount <dir>         - unmount a filesystem"
    echo "  fdisk -l             - list all disk partitions"
    echo "  blkid                - show block device UUIDs and types"
    echo "  sync                 - flush all pending disk writes"
    echo ""
    echo "  NETWORKING"
    echo "  ifconfig             - show all network interfaces"
    echo "  ifconfig eth0        - show info for eth0"
    echo "  ifconfig eth0 up     - bring eth0 interface up"
    echo "  ifconfig eth0 down   - bring eth0 interface down"
    echo "  ip addr              - show all IP addresses"
    echo "  ip addr add x <dev>  - add an IP address to an interface"
    echo "  ip route             - show the routing table"
    echo "  ip link              - show network link status"
    echo "  ping <host>          - send ICMP packets to a host"
    echo "  ping -c 4 <host>     - ping exactly 4 times"
    echo "  wget <url>           - download a file from a URL"
    echo "  wget -O <f> <url>    - download and save as specific filename"
    echo "  netstat              - show active network connections"
    echo "  netstat -tulpn       - show listening ports and programs"
    echo "  hostname             - show the system hostname"
    echo "  hostname <name>      - set the system hostname"
    echo ""
    echo "  SYSTEM"
    echo "  dmesg                - show kernel boot and hardware messages"
    echo "  dmesg | tail         - show last kernel messages"
    echo "  uname -a             - show kernel version and system info"
    echo "  uname -r             - show just the kernel version"
    echo "  uptime               - show how long the system has been running"
    echo "  date                 - show current date and time"
    echo "  date +%Y-%m-%d       - show date in YYYY-MM-DD format"
    echo "  whoami               - show the current logged in user"
    echo "  id                   - show user ID and group memberships"
    echo "  env                  - list all environment variables"
    echo "  export VAR=value     - set an environment variable"
    echo "  unset VAR            - remove an environment variable"
    echo "  history              - show previously run commands"
    echo "  clear                - clear the terminal screen"
    echo "  reboot               - reboot the system"
    echo "  poweroff             - shut the system down"
    echo "  sdulhelp            - show this command reference"
    echo ""
}

sdulhelp
alias help=sdulhelp
