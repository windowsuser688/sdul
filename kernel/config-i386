# SDUL minimal kernel config - i386
CONFIG_X86_32=y
CONFIG_M686=y
CONFIG_SMP=y
CONFIG_NR_CPUS=4
CONFIG_PREEMPT_NONE=y
CONFIG_HIGHMEM4G=y

# Basic hardware
CONFIG_PCI=y
CONFIG_ACPI=y
CONFIG_DMI=y

# Block devices
CONFIG_ATA=y
CONFIG_ATA_PIIX=y
CONFIG_SATA_AHCI=y
CONFIG_BLK_DEV_SD=y
# CONFIG_BLK_DEV_SR is not set

# Filesystems
CONFIG_EXT4_FS=y
CONFIG_TMPFS=y
CONFIG_PROC_FS=y
CONFIG_SYSFS=y
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y
# CONFIG_ISO9660_FS is not set
# CONFIG_JOLIET is not set

# Networking (minimal)
CONFIG_NET=y
CONFIG_INET=y
CONFIG_PACKET=y
CONFIG_UNIX=y
CONFIG_E1000=y
CONFIG_VIRTIO_NET=y

# TTY / Serial
CONFIG_TTY=y
CONFIG_SERIAL_8250=y
CONFIG_SERIAL_8250_CONSOLE=y
CONFIG_VT=y
CONFIG_VT_CONSOLE=y

# Initramfs
CONFIG_BLK_DEV_INITRD=y
CONFIG_INITRAMFS_SOURCE=""
CONFIG_RD_GZIP=y
CONFIG_RD_BZIP2=y

# Init / userspace
CONFIG_BINFMT_ELF=y
CONFIG_BINFMT_SCRIPT=y

# USB (basic)
CONFIG_USB=y
CONFIG_USB_EHCI_HCD=y
CONFIG_USB_STORAGE=y

# Disable graphics
# CONFIG_DRM is not set
# CONFIG_FB is not set

# Disable unused
# CONFIG_SOUND is not set
# CONFIG_MEDIA_SUPPORT is not set
# CONFIG_WIRELESS is not set
# CONFIG_BLUETOOTH is not set

CONFIG_PRINTK=y
CONFIG_EARLY_PRINTK=y
